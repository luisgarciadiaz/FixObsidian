# FixObsidian — Environment Configuration
# Copy this to .env and edit for your setup.
# This file is safe to share (no real paths).

VAULT_PATH=C:\Path\To\Your\Obsidian\Vault
LIBRARY_PATH=D:\Path\To\Your\Ebook\Library

# Set to "true" to enable subfolder organization by category
ORGANIZE_NOTES=false
